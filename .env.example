# Database (Required)
DATABASE_URL=postgresql://user:password@host:5432/flipmodel

# Auth (Required)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Encryption (Required for accounting integrations)
ENCRYPTION_KEY=generate-64-char-hex-with-node-crypto-randomBytes-32

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Xero Accounting (Optional)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# QuickBooks Accounting (Optional)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_SANDBOX=false

# Sentry (optional - error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Logging (Optional)
LOG_LEVEL=info

# Email (Optional)
EMAIL_PROVIDER=log
EMAIL_FROM=FlipModel <noreply@flipmodel.co.za>
RESEND_API_KEY=

# Cache (optional)
CACHE_ENABLED=true
