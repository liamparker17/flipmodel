generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Standard Tables ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  company       String?
  phone         String?
  preferences   Json?     // { defaultCommission, defaultContingency, bondRate, ... }
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  // Organisation membership
  orgMembers    OrgMember[]

  // Business data ownership (userId retained for audit trail)
  deals         Deal[]
  expenses      Expense[]
  milestones    Milestone[]
  contacts      Contact[]
  documents     Document[]
  tools         Tool[]
  toolCheckouts ToolCheckout[]
  toolMaintenance ToolMaintenance[]
  toolIncidents ToolIncident[]
  activities    Activity[]
  shoppingListItems ShoppingListItem[]
  notifications Notification[]
  invoices      Invoice[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Organisation ───

model Organisation {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  currency  String   @default("ZAR")
  timezone  String   @default("Africa/Johannesburg")
  settings  Json?    // OrgSettings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members              OrgMember[]
  departments          Department[]
  deals                Deal[]
  expenses             Expense[]
  milestones           Milestone[]
  contacts             Contact[]
  documents            Document[]
  tools                Tool[]
  toolCheckouts        ToolCheckout[]
  toolMaintenance      ToolMaintenance[]
  toolIncidents        ToolIncident[]
  activities           Activity[]
  shoppingListItems    ShoppingListItem[]
  notifications        Notification[]
  invoices             Invoice[]
  dealContacts         DealContact[]
  accountingConnections AccountingConnection[]
  chartOfAccounts      ChartOfAccount[]
  accountingSyncs      AccountingSync[]
  loans                Loan[]
  inspections          Inspection[]
  permits              Permit[]
  comparableSales      ComparableSale[]
  insurancePolicies    InsurancePolicy[]
  contractorRatings    ContractorRating[]
  financialPeriods     FinancialPeriod[]
  journalEntries       JournalEntry[]
  vendorBills          VendorBill[]
  billPayments         BillPayment[]
  customerReceivables  CustomerReceivable[]
  receivablePayments   ReceivablePayment[]
  purchaseOrders       PurchaseOrder[]
  goodsReceipts        GoodsReceipt[]
  inventoryItems       InventoryItem[]
  inventoryTransactions InventoryTransaction[]
  bankAccounts         BankAccount[]
  bankTransactions     BankTransaction[]
  employees            Employee[]
  leaveRecords         LeaveRecord[]
  payslips             Payslip[]
  journalEntrySequence JournalEntrySequence?

  @@index([slug])
}

model Department {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  members   OrgMember[]

  @@index([orgId])
}

model OrgMember {
  id                  String   @id @default(cuid())
  orgId               String
  userId              String
  role                String   @default("viewer") // OrgRole
  departmentId        String?
  title               String?
  moduleOverrides     Json?    // { [ModuleKey]: boolean }
  permissionOverrides Json?    // { [Permission]: boolean }
  isActive            Boolean  @default(true)
  invitedBy           String?
  joinedAt            DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  org        Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department?  @relation(fields: [departmentId], references: [id])

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

// ─── Accounting ───

model AccountingConnection {
  id             String   @id @default(cuid())
  orgId          String
  provider       String   // AccountingProvider
  status         String   @default("disconnected") // AccountingConnectionStatus
  accessToken    String?  @db.Text
  refreshToken   String?  @db.Text
  tokenExpiresAt DateTime?
  externalOrgId  String?
  lastSyncAt     DateTime?
  settings       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model OAuthState {
  id        String   @id @default(cuid())
  state     String   @unique
  orgId     String
  returnTo  String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([state])
  @@index([expiresAt])
}

model ChartOfAccount {
  id              String   @id @default(cuid())
  orgId           String
  code            String
  name            String
  type            String   // AccountType
  subtype         String   // AccountSubtype
  externalId      String?
  isActive        Boolean  @default(true)
  isSystemAccount Boolean  @default(false)
  parentId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org    Organisation   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent ChartOfAccount? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children ChartOfAccount[] @relation("AccountHierarchy")

  @@unique([orgId, code])
  @@index([orgId])
}

model AccountingSync {
  id            String    @id @default(cuid())
  orgId         String
  entityType    String
  entityId      String
  externalId    String?
  direction     String    // SyncDirection
  status        String    @default("pending") // SyncStatus
  errorMessage  String?
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, entityType, entityId])
}

// ─── Business Tables ───

model Deal {
  id                String    @id @default(cuid())
  orgId             String?
  userId            String
  name              String
  address           String    @default("")
  purchasePrice     Float     @default(0)
  expectedSalePrice Float     @default(0)
  actualSalePrice   Float?
  stage             String    @default("lead") // DealStage enum
  priority          String    @default("medium") // DealPriority enum
  notes             String    @default("")
  tags              Json      @default("[]") // string[]
  data              Json      // DealData — rooms, acquisition, holding, resale
  offerAmount       Float?
  offerDate         DateTime?
  purchaseDate      DateTime?
  transferDate      DateTime?
  listedDate        DateTime?
  soldDate          DateTime?
  actualSaleDate    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  org               Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses          Expense[]
  milestones        Milestone[]
  activities        Activity[]
  dealContacts      DealContact[]
  documents         Document[]
  shoppingListItems ShoppingListItem[]
  invoices          Invoice[]
  loans             Loan[]
  inspections       Inspection[]
  permits           Permit[]
  comparableSales   ComparableSale[]
  insurancePolicies InsurancePolicy[]
  contractorRatings ContractorRating[]

  @@index([orgId])
  @@index([orgId, stage])
  @@index([userId])
}

model Expense {
  id              String    @id @default(cuid())
  orgId           String?
  userId          String
  dealId          String
  category        String    // ExpenseCategory
  description     String
  amount          Float
  date            DateTime
  vendor          String    @default("")
  paymentMethod   String    @default("eft") // PaymentMethod
  receiptRef      String?
  notes           String?
  isProjected     Boolean   @default(false)
  milestoneId     String?
  contractorId    String?
  signOffStatus   String    @default("pending") // pending | approved | rejected
  signOffInspectedAt DateTime?
  signOffApprovedAt  DateTime?
  signOffPmNotes  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal            Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([dealId])
  @@index([userId])
}

model Milestone {
  id                    String    @id @default(cuid())
  orgId                 String?
  userId                String
  dealId                String
  title                 String
  description           String    @default("")
  dueDate               DateTime?
  completedDate         DateTime?
  status                String    @default("pending") // MilestoneStatus
  order                 Int       @default(0)
  assignedContractorId  String?
  assignedToMemberId    String?
  roomId                String?
  inspectionStatus      String?   // InspectionStatus
  inspectedAt           DateTime?
  inspectionNotes       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  org                   Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal                  Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tasks                 Task[]

  @@index([orgId])
  @@index([dealId])
}

model Task {
  id           String    @id @default(cuid())
  milestoneId  String
  title        String
  completed    Boolean   @default(false)
  assignedTo   String?
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  milestone    Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
}

model Activity {
  id          String   @id @default(cuid())
  orgId       String
  userId      String
  dealId      String
  type        String   // ActivityType
  description String
  metadata    Json?
  timestamp   DateTime @default(now())

  org         Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([dealId])
  @@index([userId])
  @@index([dealId, timestamp])
}

// ─── CRM: Top-level Contacts ───

model Contact {
  id           String    @id @default(cuid())
  orgId        String?
  userId       String
  name         String
  role         String    @default("other") // ContactRole
  company      String?
  phone        String?
  email        String?
  notes        String?
  profession   String?
  dailyRate    Float?
  bankName     String?
  accountNumber String?
  branchCode   String?
  accountType  String?   // cheque | savings | business
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  org          Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealContacts DealContact[]
  ratings      ContractorRating[]

  @@index([orgId])
  @@index([orgId, role])
  @@index([userId])
}

model DealContact {
  id              String  @id @default(cuid())
  orgId           String?
  dealId          String
  contactId       String
  workDescription String?
  daysWorked      Float?

  org             Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal            Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact         Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([dealId, contactId])
  @@index([orgId])
  @@index([dealId])
  @@index([contactId])
}

model Document {
  id        String   @id @default(cuid())
  orgId     String?
  userId    String
  dealId    String?
  name      String
  type      String   // DocumentType
  url       String?
  notes     String?
  fileSize  Int?
  mimeType  String?
  createdAt DateTime @default(now())

  org       Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([dealId])
  @@index([userId])
}

model ShoppingListItem {
  id              String   @id @default(cuid())
  orgId           String?
  userId          String
  dealId          String
  materialKey     String
  category        String
  purchased       Boolean  @default(false)
  actualPrice     Float?
  actualQty       Float?
  vendor          String?
  purchasedDate   DateTime?
  notes           String?
  stylePreferences Json?
  isCustom        Boolean  @default(false)
  label           String?
  qty             Float?
  unit            String?
  unitPrice       Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org             Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, materialKey])
  @@index([orgId])
  @@index([dealId])
}

// ─── Tool Locker ───

model Tool {
  id                  String   @id @default(cuid())
  orgId               String?
  userId              String
  name                String
  category            String   // ToolCategoryKey
  brand               String?
  model               String?
  serialNumber        String?
  purchaseDate        DateTime?
  purchaseCost        Float    @default(0)
  expectedLifespanMonths Int   @default(24)
  replacementCost     Float    @default(0)
  status              String   @default("available") // ToolStatus
  condition           String   @default("new") // ToolCondition
  currentHolderType   String?
  currentHolderId     String?
  currentHolderName   String?
  currentDealId       String?
  currentDealName     String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  org                 Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkouts           ToolCheckout[]
  maintenance         ToolMaintenance[]
  incidents           ToolIncident[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([userId])
}

model ToolCheckout {
  id                 String    @id @default(cuid())
  orgId              String?
  userId             String
  toolId             String
  contractorName     String
  contractorId       String?
  dealId             String?
  dealName           String?
  propertyAddress    String?
  checkedOutAt       DateTime  @default(now())
  expectedReturnDate DateTime?
  returnedAt         DateTime?
  conditionOut       String    // ToolCondition
  conditionIn        String?   // ToolCondition
  notes              String?
  createdAt          DateTime  @default(now())

  org                Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool               Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([toolId])
  @@index([userId])
}

model ToolMaintenance {
  id          String   @id @default(cuid())
  orgId       String?
  userId      String
  toolId      String
  date        DateTime
  type        String   // service | repair | blade_change | calibration | other
  description String
  cost        Float?
  performedBy String?
  notes       String?
  createdAt   DateTime @default(now())

  org         Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool        Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([toolId])
}

model ToolIncident {
  id              String   @id @default(cuid())
  orgId           String?
  userId          String
  toolId          String
  date            DateTime
  type            String   // lost | stolen | damaged | broken
  contractorName  String
  contractorId    String?
  dealId          String?
  dealName        String?
  description     String
  estimatedCost   Float?
  recoveryStatus  String   @default("pending") // pending | charged_back | written_off | resolved
  recoveryAmount  Float?
  notes           String?
  createdAt       DateTime @default(now())

  org             Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool            Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([toolId])
  @@index([userId])
}

// ─── Notifications ───

model Notification {
  id        String   @id @default(cuid())
  orgId     String?
  userId    String
  type      String   // deadline_warning | budget_alert | tool_overdue | milestone_overdue | general
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  org       Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([userId, read])
  @@index([userId])
}

// ─── Invoicing ───

model Invoice {
  id            String    @id @default(cuid())
  orgId         String?
  userId        String
  dealId        String?
  invoiceNumber String
  contactId     String?
  status        String    @default("draft") // draft | sent | paid | overdue
  issueDate     DateTime  @default(now())
  dueDate       DateTime?
  subtotal      Float     @default(0)
  tax           Float     @default(0)
  total         Float     @default(0)
  notes         String?
  lineItems     Json      @default("[]") // InvoiceLineItem[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  org           Organisation? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal          Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([userId])
  @@index([dealId])
}

// ─── Loans / Mortgages ───

model Loan {
  id              String    @id @default(cuid())
  orgId           String
  dealId          String
  lender          String
  loanType        String    @default("bond") // bond, bridging, private, cash
  amount          Float
  interestRate    Float
  termMonths      Int
  monthlyPayment  Float     @default(0)
  approvalStatus  String    @default("pending") // pending, pre_approved, approved, declined
  approvalDate    DateTime?
  disbursementDate DateTime?
  maturityDate    DateTime?
  notes           String    @default("")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal            Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([dealId])
}

// ─── Inspections & Defects ───

model Inspection {
  id              String    @id @default(cuid())
  orgId           String
  dealId          String
  type            String    @default("general") // general, structural, electrical, plumbing, pest, roof
  inspector       String    @default("")
  inspectionDate  DateTime?
  status          String    @default("scheduled") // scheduled, completed, passed, failed, conditional
  reportUrl       String?
  findings        String    @default("")
  estimatedRepairCost Float @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal            Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  defects         Defect[]

  @@index([orgId])
  @@index([dealId])
}

model Defect {
  id              String    @id @default(cuid())
  inspectionId    String
  location        String    @default("")
  description     String
  severity        String    @default("minor") // minor, moderate, major, critical
  estimatedCost   Float     @default(0)
  status          String    @default("open") // open, remediated, accepted, deferred
  remediatedAt    DateTime?
  notes           String    @default("")
  createdAt       DateTime  @default(now())

  inspection      Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
}

// ─── Permits ───

model Permit {
  id              String    @id @default(cuid())
  orgId           String
  dealId          String
  permitType      String    // building, electrical, plumbing, demolition, zoning, occupancy
  permitNumber    String    @default("")
  status          String    @default("not_applied") // not_applied, applied, approved, denied, expired
  appliedDate     DateTime?
  approvedDate    DateTime?
  expiryDate      DateTime?
  issuingAuthority String   @default("")
  cost            Float     @default(0)
  notes           String    @default("")
  documentUrl     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal            Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([dealId])
}

// ─── Comparable Sales ───

model ComparableSale {
  id              String    @id @default(cuid())
  orgId           String
  dealId          String
  address         String
  salePrice       Float
  saleDate        DateTime?
  sqm             Float     @default(0)
  pricePerSqm     Float     @default(0)
  bedrooms        Int       @default(0)
  bathrooms       Int       @default(0)
  condition       String    @default("average") // poor, below_average, average, good, excellent
  source          String    @default("") // lightstone, property24, agent, manual
  notes           String    @default("")
  createdAt       DateTime  @default(now())

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal            Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([dealId])
}

// ─── Insurance Policies ───

model InsurancePolicy {
  id              String    @id @default(cuid())
  orgId           String
  dealId          String?
  policyType      String    // builders_risk, liability, property, contents, construction
  provider        String    @default("")
  policyNumber    String    @default("")
  coverAmount     Float     @default(0)
  monthlyPremium  Float     @default(0)
  startDate       DateTime?
  endDate         DateTime?
  status          String    @default("active") // active, expired, cancelled, claimed
  notes           String    @default("")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal            Deal?      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([dealId])
}

// ─── Contractor Ratings ───

model ContractorRating {
  id              String    @id @default(cuid())
  orgId           String
  contactId       String
  dealId          String?
  qualityScore    Int       @default(3) // 1-5
  timelinessScore Int       @default(3) // 1-5
  communicationScore Int    @default(3) // 1-5
  valueScore      Int       @default(3) // 1-5
  overallScore    Float     @default(3)
  review          String    @default("")
  wouldRehire     Boolean   @default(true)
  createdAt       DateTime  @default(now())

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact         Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal            Deal?      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([contactId])
  @@index([dealId])
}

// ─── Audit Log ───

model AuditLog {
  id          String   @id @default(cuid())
  orgId       String
  userId      String
  action      String   // create | update | delete | approve | reject | login | logout
  entityType  String   // deal | expense | invoice | journal_entry | vendor_bill | etc.
  entityId    String?
  changes     Json?    // { field: { old, new } }
  metadata    Json?    // Additional context
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([orgId])
  @@index([orgId, entityType])
  @@index([orgId, userId])
  @@index([orgId, createdAt])
  @@index([entityType, entityId])
}

// ─── Financial Periods ───

model FinancialPeriod {
  id          String    @id @default(cuid())
  orgId       String
  name        String    // "2026-01", "2026-02", etc.
  startDate   DateTime
  endDate     DateTime
  status      String    @default("open") // open | closed | locked
  closedBy    String?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org         Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
  @@index([orgId, status])
}

// ─── Sequences ───

model JournalEntrySequence {
  orgId   String @id
  lastSeq Int    @default(0)

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

// ─── General Ledger ───

model JournalEntry {
  id            String    @id @default(cuid())
  orgId         String
  userId        String
  entryNumber   String    // Auto-generated: JE-000001
  date          DateTime
  description   String
  reference     String?   // External reference (invoice #, bill #, etc.)
  sourceType    String?   // expense | invoice | vendor_bill | manual | adjustment
  sourceId      String?   // ID of the source record
  status        String    @default("draft") // draft | posted | reversed
  reversalOf    String?   // If this reverses another entry
  periodName    String?   // Financial period this belongs to
  notes         String?
  postedAt      DateTime?
  postedBy      String?
  version       Int       @default(1) // Optimistic locking
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  org           Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lines         JournalLine[]

  @@unique([orgId, entryNumber])
  @@index([orgId])
  @@index([orgId, date])
  @@index([orgId, status])
  @@index([sourceType, sourceId])
}

model JournalLine {
  id              String   @id @default(cuid())
  journalEntryId  String
  accountCode     String   // References ChartOfAccount.code
  accountName     String   // Denormalized for reporting speed
  description     String?
  debit           Float    @default(0)
  credit          Float    @default(0)
  dealId          String?  // Optional deal allocation
  contactId       String?  // Optional contact reference
  order           Int      @default(0)

  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountCode])
  @@index([dealId])
}

// ─── Accounts Payable ───

model VendorBill {
  id              String    @id @default(cuid())
  orgId           String
  userId          String
  billNumber      String    // Vendor's invoice/bill number
  contactId       String?   // Vendor/supplier contact
  dealId          String?   // Optional deal allocation
  status          String    @default("draft") // draft | approved | partially_paid | paid | overdue | cancelled
  issueDate       DateTime  @default(now())
  dueDate         DateTime?
  subtotal        Float     @default(0)
  tax             Float     @default(0)
  total           Float     @default(0)
  amountPaid      Float     @default(0)
  currency        String    @default("ZAR")
  notes           String?
  documentUrl     String?
  journalEntryId  String?   // Link to GL posting
  version         Int       @default(1) // Optimistic locking
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lines           VendorBillLine[]
  payments        BillPayment[]

  @@unique([orgId, billNumber])
  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, dueDate])
  @@index([contactId])
  @@index([dealId])
}

model VendorBillLine {
  id              String   @id @default(cuid())
  vendorBillId    String
  description     String
  quantity        Float    @default(1)
  unitPrice       Float    @default(0)
  amount          Float    @default(0)
  accountCode     String?  // GL account allocation
  dealId          String?  // Line-level deal allocation
  order           Int      @default(0)

  vendorBill      VendorBill @relation(fields: [vendorBillId], references: [id], onDelete: Cascade)

  @@index([vendorBillId])
}

model BillPayment {
  id              String    @id @default(cuid())
  orgId           String
  vendorBillId    String
  amount          Float
  paymentDate     DateTime
  paymentMethod   String    @default("eft") // eft | cash | card | cheque
  reference       String?   // Payment reference number
  bankAccountId   String?
  journalEntryId  String?
  idempotencyKey  String?   // Client-provided key to prevent duplicate payments
  notes           String?
  createdAt       DateTime  @default(now())

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendorBill      VendorBill @relation(fields: [vendorBillId], references: [id], onDelete: Cascade)

  @@unique([orgId, idempotencyKey])
  @@index([orgId])
  @@index([vendorBillId])
  @@index([bankAccountId])
}

// ─── Accounts Receivable ───

model CustomerReceivable {
  id              String    @id @default(cuid())
  orgId           String
  userId          String
  invoiceId       String?   // Link to existing Invoice
  contactId       String?   // Customer contact
  dealId          String?
  status          String    @default("outstanding") // outstanding | partially_paid | paid | overdue | written_off
  totalAmount     Float     @default(0)
  amountPaid      Float     @default(0)
  dueDate         DateTime?
  currency        String    @default("ZAR")
  journalEntryId  String?
  notes           String?
  version         Int       @default(1) // Optimistic locking
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  payments        ReceivablePayment[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, dueDate])
  @@index([contactId])
  @@index([invoiceId])
}

model ReceivablePayment {
  id                  String    @id @default(cuid())
  orgId               String
  customerReceivableId String
  amount              Float
  paymentDate         DateTime
  paymentMethod       String    @default("eft")
  reference           String?
  bankAccountId       String?
  journalEntryId      String?
  idempotencyKey      String?   // Client-provided key to prevent duplicate payments
  notes               String?
  createdAt           DateTime  @default(now())

  org                 Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customerReceivable  CustomerReceivable @relation(fields: [customerReceivableId], references: [id], onDelete: Cascade)

  @@unique([orgId, idempotencyKey])
  @@index([orgId])
  @@index([customerReceivableId])
  @@index([bankAccountId])
}

// ─── Purchase Orders ───

model PurchaseOrder {
  id              String    @id @default(cuid())
  orgId           String
  userId          String
  poNumber        String    // Auto-generated: PO-000001
  contactId       String?   // Supplier contact
  dealId          String?
  status          String    @default("draft") // draft | submitted | approved | partially_received | received | cancelled
  orderDate       DateTime  @default(now())
  expectedDate    DateTime?
  subtotal        Float     @default(0)
  tax             Float     @default(0)
  total           Float     @default(0)
  shippingCost    Float     @default(0)
  currency        String    @default("ZAR")
  deliveryAddress String?
  notes           String?
  approvedBy      String?
  approvedAt      DateTime?
  vendorBillId    String?   // Link to AP when billed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lines           PurchaseOrderLine[]
  receipts        GoodsReceipt[]

  @@unique([orgId, poNumber])
  @@index([orgId])
  @@index([orgId, status])
  @@index([contactId])
  @@index([dealId])
}

model PurchaseOrderLine {
  id                String   @id @default(cuid())
  purchaseOrderId   String
  description       String
  quantity          Float    @default(1)
  unitPrice         Float    @default(0)
  amount            Float    @default(0)
  quantityReceived  Float    @default(0)
  inventoryItemId   String?
  accountCode       String?
  order             Int      @default(0)

  purchaseOrder     PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

model GoodsReceipt {
  id                String    @id @default(cuid())
  orgId             String
  purchaseOrderId   String
  receivedDate      DateTime  @default(now())
  receivedBy        String
  notes             String?
  items             Json      // [{ lineId, quantityReceived, condition }]
  createdAt         DateTime  @default(now())

  org               Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  purchaseOrder     PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([purchaseOrderId])
}

// ─── Inventory ───

model InventoryItem {
  id              String    @id @default(cuid())
  orgId           String
  sku             String
  name            String
  description     String?
  category        String    @default("materials") // materials | fixtures | fittings | consumables | equipment
  unit            String    @default("each") // each | m | m2 | m3 | kg | litre | box | pack
  quantityOnHand  Float     @default(0)
  quantityReserved Float    @default(0)
  reorderPoint    Float     @default(0)
  reorderQuantity Float     @default(0)
  costPrice       Float     @default(0) // Weighted average cost
  lastPurchasePrice Float   @default(0)
  location        String?   // Warehouse/storage location
  isActive        Boolean   @default(true)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  transactions    InventoryTransaction[]

  @@unique([orgId, sku])
  @@index([orgId])
  @@index([orgId, category])
  @@index([orgId, quantityOnHand])
}

model InventoryTransaction {
  id              String    @id @default(cuid())
  orgId           String
  inventoryItemId String
  type            String    // purchase | sale | adjustment | transfer | usage | return
  quantity        Float     // Positive = in, negative = out
  unitCost        Float     @default(0)
  totalCost       Float     @default(0)
  reference       String?   // PO number, deal name, etc.
  referenceType   String?   // purchase_order | deal | adjustment | transfer
  referenceId     String?
  dealId          String?   // Which deal consumed this inventory
  notes           String?
  performedBy     String
  createdAt       DateTime  @default(now())

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([inventoryItemId])
  @@index([orgId, type])
  @@index([dealId])
  @@index([referenceType, referenceId])
}

// ─── Bank Accounts & Reconciliation ───

model BankAccount {
  id              String    @id @default(cuid())
  orgId           String
  name            String    // "FNB Business Cheque", etc.
  bankName        String
  accountNumber   String
  branchCode      String?
  accountType     String    @default("cheque") // cheque | savings | credit | trust
  currency        String    @default("ZAR")
  currentBalance  Float     @default(0)
  accountCode     String?   // GL account code
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  transactions    BankTransaction[]

  @@index([orgId])
  @@index([orgId, isActive])
}

model BankTransaction {
  id              String    @id @default(cuid())
  orgId           String
  bankAccountId   String
  date            DateTime
  description     String
  amount          Float     // Positive = deposit, negative = withdrawal
  balance         Float?    // Running balance from bank statement
  reference       String?
  type            String    @default("other") // deposit | withdrawal | transfer | fee | interest | other
  category        String?
  isReconciled    Boolean   @default(false)
  reconciledAt    DateTime?
  matchedEntityType String? // expense | bill_payment | receivable_payment | journal_entry
  matchedEntityId String?
  importBatch     String?   // For statement imports
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([bankAccountId])
  @@index([bankAccountId, date])
  @@index([bankAccountId, isReconciled])
  @@index([matchedEntityType, matchedEntityId])
}

// ─── HR / Payroll ───

model Employee {
  id              String    @id @default(cuid())
  orgId           String
  userId          String?   // Optional link to a User account
  contactId       String?   // Optional link to a Contact
  employeeNumber  String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  idNumber        String?   // SA ID number (encrypted)
  taxNumber       String?   // SARS tax number
  position        String    @default("")
  department      String?
  employmentType  String    @default("full_time") // full_time | part_time | contract | temporary
  startDate       DateTime
  endDate         DateTime?
  status          String    @default("active") // active | on_leave | terminated | suspended
  bankName        String?
  accountNumber   String?   // Encrypted
  branchCode      String?
  baseSalary      Float     @default(0)
  hourlyRate      Float?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  leaveRecords    LeaveRecord[]
  payslips        Payslip[]

  @@unique([orgId, employeeNumber])
  @@index([orgId])
  @@index([orgId, status])
}

model LeaveRecord {
  id              String    @id @default(cuid())
  orgId           String
  employeeId      String
  leaveType       String    @default("annual") // annual | sick | family | unpaid | maternity | paternity | study
  startDate       DateTime
  endDate         DateTime
  days            Float     @default(1)
  status          String    @default("pending") // pending | approved | rejected | cancelled
  reason          String?
  approvedBy      String?
  approvedAt      DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([employeeId])
  @@index([orgId, status])
}

model Payslip {
  id              String    @id @default(cuid())
  orgId           String
  employeeId      String
  periodStart     DateTime
  periodEnd       DateTime
  basePay         Float     @default(0)
  overtime        Float     @default(0)
  bonus           Float     @default(0)
  commission      Float     @default(0)
  grossPay        Float     @default(0)
  paye            Float     @default(0) // Pay As You Earn tax
  uif             Float     @default(0) // Unemployment Insurance Fund
  pensionFund     Float     @default(0)
  medicalAid      Float     @default(0)
  otherDeductions Float     @default(0)
  totalDeductions Float     @default(0)
  netPay          Float     @default(0)
  status          String    @default("draft") // draft | approved | paid
  paymentDate     DateTime?
  paymentRef      String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org             Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([employeeId])
  @@index([orgId, status])
  @@index([orgId, periodStart])
}
